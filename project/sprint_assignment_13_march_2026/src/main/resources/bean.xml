<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->

    <context:annotation-config/>
    <bean id="emp" class ="org.example.beans.Employee">
        <property name="empId" value="101"/>
        <property name="name" value="Harriet"/>
        <property name="salary" value="40000.0"/>
        <property name="age" value="30"/>

    </bean>
    <bean id="emp1" class ="org.example.beans.Employee">
        <property name="empId" value="102"/>
        <property name="name" value="Harry"/>
        <property name="salary" value="40000.0"/>
        <property name="age" value="30"/>

    </bean>
    <bean id="sbu" class ="org.example.beans.SBU">
       <property name="subId" value="10"/>
        <property name="sbuName" value="Product Engineering Services"/>
        <property name="sbuHead" value="kiran Rao"/>
        <property name="emp">
            <list>
                <ref bean="emp"/>
                <ref bean="emp1"/>
            </list>
        </property>
    </bean>




</beans>
